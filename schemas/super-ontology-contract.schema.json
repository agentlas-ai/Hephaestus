{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.dev/schemas/super-ontology-contract.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "state",
    "projectId",
    "runtimeGraphWriteEnabled",
    "zeroErrorClaim",
    "layers",
    "evidenceLedgers",
    "hardStops",
    "promotionPolicy"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": { "const": "agentlas-super-ontology-contract" },
    "state": {
      "enum": ["export_only", "local_candidate", "shadow", "canary", "active", "archived"]
    },
    "projectId": { "type": "string" },
    "draftId": { "type": ["string", "null"] },
    "runtimeGraphWriteEnabled": { "const": false },
    "zeroErrorClaim": { "const": false },
    "layers": {
      "type": "array",
      "items": {
        "enum": [
          "source_intake",
          "evidence_packet",
          "belief_ledger",
          "knowledge_capsule",
          "affordance_action_binding",
          "task_coverage_contract",
          "contextual_flow_contract",
          "causal_impact_contract",
          "assurance_case_contract",
          "knowledge_homeostasis_contract",
          "adversarial_provenance_contract",
          "epistemic_calibration_contract",
          "semantic_alignment_contract",
          "agentlas_integration_contract",
          "memory_curator_bridge",
          "promotion_readiness",
          "promotion_replay_drill",
          "architecture_sync_review"
        ]
      },
      "minItems": 1
    },
    "evidenceLedgers": {
      "type": "object",
      "required": [
        "replays",
        "promotionEvidence",
        "taskCoverage",
        "contextualFlow",
        "causalImpact",
        "assuranceCase",
        "knowledgeHomeostasis",
        "adversarialProvenance",
        "epistemicCalibration",
        "semanticAlignment",
        "memoryCuratorBridge",
        "memoryTickets"
      ],
      "properties": {
        "replays": { "type": "string" },
        "promotionEvidence": { "type": "string" },
        "taskCoverage": { "type": "string" },
        "contextualFlow": { "type": "string" },
        "causalImpact": { "type": "string" },
        "assuranceCase": { "type": "string" },
        "knowledgeHomeostasis": { "type": "string" },
        "adversarialProvenance": { "type": "string" },
        "epistemicCalibration": { "type": "string" },
        "semanticAlignment": { "type": "string" },
        "memoryCuratorBridge": { "type": "string" },
        "memoryTickets": { "type": "string" }
      },
      "additionalProperties": false
    },
    "hardStops": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "promotionPolicy": {
      "type": "object",
      "required": [
        "shadowRequired",
        "canaryRequiredForMixedContext",
        "rollbackRequired",
        "syncReviewRequired",
        "taskCoverageRequired",
        "contextualFlowRequired",
        "causalImpactRequired",
        "assuranceCaseRequired",
        "knowledgeHomeostasisRequired",
        "adversarialProvenanceRequired",
        "untrustedSourceRuntimeWritesBlocked",
        "epistemicCalibrationRequired",
        "uncalibratedRuntimeWritesBlocked",
        "semanticAlignmentRequired",
        "highAuthorityAlignmentReviewRequired",
        "unreviewedSemanticRuntimeWritesBlocked",
        "memoryCuratorBridgeRequired",
        "directDurableMemoryWritesBlocked",
        "appbridgeSourceWritesBlocked"
      ],
      "properties": {
        "shadowRequired": { "const": true },
        "canaryRequiredForMixedContext": { "const": true },
        "rollbackRequired": { "const": true },
        "syncReviewRequired": { "const": true },
        "taskCoverageRequired": { "const": true },
        "contextualFlowRequired": { "const": true },
        "causalImpactRequired": { "const": true },
        "assuranceCaseRequired": { "const": true },
        "knowledgeHomeostasisRequired": { "const": true },
        "adversarialProvenanceRequired": { "const": true },
        "untrustedSourceRuntimeWritesBlocked": { "const": true },
        "epistemicCalibrationRequired": { "const": true },
        "uncalibratedRuntimeWritesBlocked": { "const": true },
        "semanticAlignmentRequired": { "const": true },
        "highAuthorityAlignmentReviewRequired": { "const": true },
        "unreviewedSemanticRuntimeWritesBlocked": { "const": true },
        "memoryCuratorBridgeRequired": { "const": true },
        "directDurableMemoryWritesBlocked": { "const": true },
        "appbridgeSourceWritesBlocked": { "const": true }
      },
      "additionalProperties": false
    },
    "surfacePolicy": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["defaultDecision"],
        "properties": {
          "defaultDecision": {
            "enum": ["candidate_only", "shadow_required", "canary_required", "sync_review_required", "blocked"]
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
