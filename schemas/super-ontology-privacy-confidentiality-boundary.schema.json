{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.dev/schemas/super-ontology-privacy-confidentiality-boundary.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "state",
    "runtimePromotionAllowed",
    "defaultDecision",
    "dataClassifications",
    "boundarySurfaces",
    "requiredPrivacyEvidence",
    "hardStops",
    "researchBasis"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": { "const": "agentlas-super-ontology-privacy-confidentiality-boundary" },
    "state": { "const": "export_only" },
    "runtimePromotionAllowed": { "const": false },
    "defaultDecision": {
      "const": "privacy_boundary_evidence_required_before_graph_memory_public_training_tool_route_customer_output_personalization_retrieval_or_analytics_authority"
    },
    "dataClassifications": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "boundarySurfaces": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "requiredPrivacyEvidence": { "type": "array", "items": { "type": "string" }, "minItems": 20 },
    "hardStops": { "type": "array", "items": { "type": "string" }, "minItems": 20 },
    "researchBasis": { "type": "array", "items": { "type": "string" }, "minItems": 10 }
  },
  "additionalProperties": true
}
