{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.dev/schemas/super-ontology-source-lineage-version.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "state",
    "runtimePromotionAllowed",
    "defaultDecision",
    "documentFamilies",
    "sourceArtifactTypes",
    "lineageEvents",
    "versionStates",
    "derivationStates",
    "authorityStates",
    "transformationTypes",
    "identityResolutionStates",
    "freshnessStates",
    "requiredLineageEvidence",
    "decisions",
    "researchBasis",
    "hardStops"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": { "const": "agentlas-super-ontology-source-lineage-version" },
    "state": { "enum": ["export_only", "local_candidate", "shadow", "canary", "active", "archived"] },
    "runtimePromotionAllowed": { "const": false },
    "defaultDecision": { "type": "string" },
    "documentFamilies": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "sourceArtifactTypes": { "type": "array", "items": { "type": "string" }, "minItems": 14 },
    "lineageEvents": { "type": "array", "items": { "type": "string" }, "minItems": 14 },
    "versionStates": { "type": "array", "items": { "type": "string" }, "minItems": 9 },
    "derivationStates": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "authorityStates": { "type": "array", "items": { "type": "string" }, "minItems": 7 },
    "transformationTypes": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "identityResolutionStates": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "freshnessStates": { "type": "array", "items": { "type": "string" }, "minItems": 7 },
    "requiredLineageEvidence": { "type": "array", "items": { "type": "string" }, "minItems": 18 },
    "decisions": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "researchBasis": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "hardStops": { "type": "array", "items": { "type": "string" }, "minItems": 20 }
  },
  "additionalProperties": false
}
