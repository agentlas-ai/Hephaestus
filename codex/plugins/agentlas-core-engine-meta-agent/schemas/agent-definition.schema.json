{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/agent-definition.schema.json",
  "title": "Agentlas AgentDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "agentDefinitionId", "releaseId", "authorRef",
    "version", "packageHash", "entrypoint", "capabilities", "mcpPolicyRef",
    "thirdPartyExperiencePolicy", "visibility", "status", "contextBudget"
  ],
  "properties": {
    "schemaVersion": { "const": "agentlas.agent-definition.v1" },
    "kind": { "const": "agentlas-agent-definition" },
    "agentDefinitionId": { "$ref": "#/$defs/id" },
    "releaseId": { "$ref": "#/$defs/id" },
    "authorRef": { "$ref": "#/$defs/id" },
    "version": { "$ref": "#/$defs/id" },
    "packageHash": { "$ref": "#/$defs/hash" },
    "entrypoint": { "$ref": "#/$defs/path" },
    "capabilities": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "mcpPolicyRef": { "$ref": "#/$defs/path" },
    "thirdPartyExperiencePolicy": {
      "enum": ["denied", "private-only", "public-allowed", "approval-required"]
    },
    "visibility": { "enum": ["private", "unlisted", "public"] },
    "status": { "enum": ["draft", "active", "suspended", "deprecated", "deleted"] },
    "contextBudget": { "$ref": "#/$defs/contextBudget" },
    "createdAt": { "type": "string", "format": "date-time" },
    "releasedAt": { "type": ["string", "null"], "format": "date-time" },
    "supersedesReleaseId": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]{2,255}$" },
    "path": { "type": "string", "pattern": "^(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))[A-Za-z0-9._/\\\\-]+$" },
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "contextBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coreMemoryMaxTokens", "experienceRetrievalMaxTokens", "experienceRetrievalMaxItems"],
      "properties": {
        "coreMemoryMaxTokens": { "type": "integer", "minimum": 0, "maximum": 150 },
        "experienceRetrievalMaxTokens": { "type": "integer", "minimum": 0, "maximum": 800 },
        "experienceRetrievalMaxItems": { "type": "integer", "minimum": 0, "maximum": 8 }
      }
    }
  }
}
