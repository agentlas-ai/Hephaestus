{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.dev/schemas/super-ontology-invariant-verification.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "state",
    "runtimePromotionAllowed",
    "defaultDecision",
    "eventStreams",
    "invariantTypes",
    "temporalOperators",
    "monitors",
    "violationActions",
    "researchBasis",
    "hardStops"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": { "const": "agentlas-super-ontology-invariant-verification" },
    "state": { "enum": ["export_only", "local_candidate", "shadow", "canary", "active", "archived"] },
    "runtimePromotionAllowed": { "const": false },
    "defaultDecision": { "type": "string" },
    "eventStreams": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "invariantTypes": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "temporalOperators": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "monitors": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "violationActions": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "researchBasis": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "hardStops": { "type": "array", "items": { "type": "string" }, "minItems": 8 }
  },
  "additionalProperties": false
}
