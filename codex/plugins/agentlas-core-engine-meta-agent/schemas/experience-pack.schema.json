{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/experience-pack.schema.json",
  "title": "Agentlas ExperiencePack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "experiencePackId", "releaseId", "ownerRef", "version",
    "baseCompatibility", "itemIds", "evidenceReceiptIds", "mcpRequirements",
    "containsBasePackageMaterial", "contentHash", "visibility", "status"
  ],
  "properties": {
    "schemaVersion": { "const": "agentlas.experience-pack.v1" },
    "kind": { "const": "agentlas-experience-pack" },
    "experiencePackId": { "$ref": "#/$defs/id" },
    "releaseId": { "$ref": "#/$defs/id" },
    "ownerRef": { "$ref": "#/$defs/id" },
    "version": { "type": "string", "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$", "maxLength": 64 },
    "baseCompatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agentDefinitionId", "compatibleBaseReleaseIds"],
      "properties": {
        "agentDefinitionId": { "$ref": "#/$defs/id" },
        "compatibleBaseReleaseIds": {
          "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "itemIds": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "evidenceReceiptIds": { "type": "array", "maxItems": 6144, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "mcpRequirements": {
      "type": "array", "maxItems": 64, "uniqueItems": true,
      "items": { "$ref": "mcp-requirement.schema.json" }
    },
    "containsBasePackageMaterial": { "const": false },
    "contentHash": { "$ref": "#/$defs/hash" },
    "visibility": { "enum": ["private", "unlisted", "public"] },
    "status": { "enum": ["draft", "active", "suspended", "withdrawn", "deleted"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "releasedAt": { "type": ["string", "null"], "format": "date-time" },
    "withdrawnAt": { "type": ["string", "null"], "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "active" } }, "required": ["status"] },
      "then": { "properties": { "itemIds": { "minItems": 1 } } }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]{2,255}$" },
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
