{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.cloud/schemas/agentlas-manifest.schema.json",
  "title": "Agentlas Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "packageHash",
    "runtimeBundleVersion",
    "entry",
    "skills",
    "toolPermissions",
    "memoryPolicy",
    "allowRead",
    "denyRead",
    "publicExportPolicy",
    "requiredRuntime",
    "license",
    "createdBy"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "name": { "type": "string", "minLength": 1 },
    "packageHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "runtimeBundleVersion": { "const": "1.0" },
    "entry": { "type": "string", "minLength": 1 },
    "skills": { "type": "array", "items": { "type": "string" } },
    "toolPermissions": {
      "type": "object",
      "required": ["network", "shell", "fileRead"],
      "properties": {
        "network": { "enum": ["allow", "ask", "deny"] },
        "shell": { "enum": ["allow", "ask", "deny"] },
        "fileRead": { "const": "manifest-allowlist" }
      },
      "additionalProperties": false
    },
    "memoryPolicy": {
      "type": "object",
      "required": ["writeBack", "publicCopy"],
      "properties": {
        "writeBack": { "enum": ["off", "ask", "auto"] },
        "publicCopy": { "const": "reset" }
      },
      "additionalProperties": false
    },
    "memory": { "type": "array", "items": { "type": "string" } },
    "allowRead": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "denyRead": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "publicExportPolicy": { "const": "clean-copy" },
    "requiredRuntime": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "license": { "enum": ["call-only-default", "source-download-allowed"] },
    "createdBy": { "type": "string", "minLength": 1 },
    "packageHashVersion": { "const": "agentlas-package-hash/v2" },
    "assetContract": {
      "type": "object",
      "required": ["kind", "schemaVersion", "materialization", "releaseAuthority"],
      "properties": {
        "kind": { "const": "agent-definition" },
        "schemaVersion": { "const": "agentlas.agent-definition.v1" },
        "materialization": { "const": "hub-or-cloud-registration" },
        "releaseAuthority": { "const": "registry" },
        "agentDefinitionId": { "type": "string", "minLength": 1 },
        "releaseId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "mcpPolicy": {
      "type": "object",
      "required": ["ref", "resolution"],
      "properties": {
        "ref": { "const": ".agentlas/mcp-policy.json" },
        "resolution": { "const": "system-global-first" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
