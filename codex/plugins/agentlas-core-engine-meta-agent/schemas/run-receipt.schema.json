{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/run-receipt.schema.json",
  "title": "Agentlas RunReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "receiptId", "idempotencyKey", "receiptHash", "runId",
    "agentDefinitionReleaseId", "experiencePackReleaseId", "variantId", "taskSignature",
    "environment", "resources", "outcome", "verification", "metricsEligible", "metrics",
    "sideEffects", "privacy", "createdAt"
  ],
  "properties": {
    "schemaVersion": { "const": "agentlas.run-receipt.v1" },
    "kind": { "const": "agentlas-run-receipt" },
    "receiptId": { "$ref": "#/$defs/id" },
    "idempotencyKey": { "$ref": "#/$defs/id" },
    "receiptHash": { "$ref": "#/$defs/hash" },
    "runId": { "$ref": "#/$defs/id" },
    "agentDefinitionReleaseId": { "$ref": "#/$defs/id" },
    "experiencePackReleaseId": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
    "variantId": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
    "taskSignature": {
      "type": "object", "additionalProperties": false, "required": ["kind", "hash"],
      "properties": { "kind": { "$ref": "#/$defs/id" }, "hash": { "$ref": "#/$defs/hash" }, "locale": { "type": "string", "maxLength": 20 } }
    },
    "environment": {
      "type": "object", "additionalProperties": false, "required": ["runtime", "os", "arch", "fingerprintHash"],
      "properties": {
        "runtime": { "$ref": "#/$defs/id" }, "os": { "$ref": "#/$defs/id" }, "arch": { "$ref": "#/$defs/id" },
        "fingerprintHash": { "$ref": "#/$defs/hash" }
      }
    },
    "resources": {
      "type": "object", "additionalProperties": false, "required": ["mcp", "skills", "model"],
      "properties": {
        "mcp": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false, "required": ["catalogId", "status"],
            "properties": {
              "catalogId": { "$ref": "#/$defs/id" },
              "status": { "enum": ["recommended", "approved", "connected", "skipped", "missing-key", "failed", "degraded"] },
              "resolvedVersion": { "type": ["string", "null"] },
              "fallbackFor": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] }
            }
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false, "required": ["id"],
            "properties": { "id": { "$ref": "#/$defs/id" }, "version": { "type": ["string", "null"] } }
          }
        },
        "model": {
          "type": "object", "additionalProperties": false, "required": ["provider", "modelId"],
          "properties": { "provider": { "$ref": "#/$defs/id" }, "modelId": { "$ref": "#/$defs/id" } }
        }
      }
    },
    "outcome": {
      "type": "object", "additionalProperties": false, "required": ["status"],
      "properties": { "status": { "enum": ["succeeded", "partial", "failed", "cancelled"] }, "failureCode": { "type": ["string", "null"], "maxLength": 120 } }
    },
    "verification": {
      "type": "object", "additionalProperties": false, "required": ["verdict", "method", "verifierRef", "evidenceRefs"],
      "properties": {
        "verdict": { "enum": ["pass", "fail", "unverified"] },
        "method": { "enum": ["automated", "human", "third-party", "self-report", "none"] },
        "verifierRef": { "type": ["string", "null"], "maxLength": 255 },
        "evidenceRefs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
      }
    },
    "metricsEligible": { "type": "boolean" },
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": ["promptTokens", "completionTokens", "totalTokens", "durationMs", "retryCount"],
      "properties": {
        "promptTokens": { "type": "integer", "minimum": 0 }, "completionTokens": { "type": "integer", "minimum": 0 },
        "totalTokens": { "type": "integer", "minimum": 0 }, "durationMs": { "type": "integer", "minimum": 0 },
        "retryCount": { "type": "integer", "minimum": 0 }
      }
    },
    "sideEffects": {
      "type": "object", "additionalProperties": false, "required": ["occurred", "adverse", "evidenceRefs"],
      "properties": {
        "occurred": { "type": "boolean" }, "adverse": { "type": "boolean" },
        "evidenceRefs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
      }
    },
    "privacy": {
      "type": "object", "additionalProperties": false,
      "required": ["rawPromptIncluded", "rawTranscriptIncluded", "rawLocalPathsIncluded", "credentialValuesIncluded"],
      "properties": {
        "rawPromptIncluded": { "const": false }, "rawTranscriptIncluded": { "const": false },
        "rawLocalPathsIncluded": { "const": false }, "credentialValuesIncluded": { "const": false }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "signature": { "type": "null" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]{2,255}$" },
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
