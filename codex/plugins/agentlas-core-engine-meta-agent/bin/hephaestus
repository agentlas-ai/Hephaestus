#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Usage:
  bin/hephaestus ontology [--gui] [--no-open] [project-dir]
  bin/hephaestus ontology add <path> [--project <dir>] [--kind company|project|personal] [--scope public|internal|private]
  bin/hephaestus wizard <agent-folder> [--name <name>]
  bin/hephaestus security scan <agent-folder> [--strict] [--acknowledge-warn] [--llm-judgment <path>]
  bin/hephaestus runtime bundle <agent-folder>
  bin/hephaestus runtime read-agent-file <agent-folder> <path>
  bin/hephaestus field-test
  bin/hephaestus meta-agent "<request>"

Examples:
  bin/hephaestus ontology
  bin/hephaestus ontology --gui .
  bin/hephaestus ontology add ./company-docs --kind company --scope private
  bin/hephaestus wizard ./some-agent --name instagram-operator
  bin/hephaestus security scan ./some-agent --strict
  bin/hephaestus runtime bundle ./some-agent
EOF
}

if [[ "${1:-}" == "" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

command="$1"
shift

case "$command" in
  ontology)
    if [[ "${1:-}" == "add" ]]; then
      shift
      PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m ontology sources add "$@"
      exit $?
    fi

    open_flag=1
    if [[ "${1:-}" == "--gui" ]]; then
      shift
    fi
    if [[ "${1:-}" == "--no-open" ]]; then
      open_flag=0
      shift
    fi
    project="${1:-.}"
    if [[ "$open_flag" == "1" ]]; then
      PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m ontology gui "$project"
    else
      PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m ontology gui "$project" --no-open
    fi
    ;;
  wizard)
    PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m agentlas_cloud wizard "$@"
    ;;
  security)
    PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m agentlas_cloud security "$@"
    ;;
  runtime)
    runtime_sub="${1:-}"
    shift || true
    case "$runtime_sub" in
      bundle)
        PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m agentlas_cloud bundle "$@"
        ;;
      read-agent-file)
        PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m agentlas_cloud read-agent-file "$@"
        ;;
      *)
        echo "hephaestus: unknown runtime command: $runtime_sub" >&2
        usage >&2
        exit 2
        ;;
    esac
    ;;
  field-test)
    PYTHONPATH="$root${PYTHONPATH:+:$PYTHONPATH}" python3 -m agentlas_cloud field-test
    ;;
  meta-agent)
    request="${*:-Create or package an Agentlas-compatible agent.}"
    cat <<EOF
Hephaestus meta-agent request:
$request

Open Claude Code or Codex with the installed plugin, then run:
/hephaestus $request
EOF
    ;;
  *)
    echo "hephaestus: unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
