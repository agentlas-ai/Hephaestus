#!/bin/sh
set -eu

state="${1:-}"
[ "$state" = "prepared" ] || exit 0

while read -r old_oid new_oid ref_name; do
  case "$ref_name" in
    refs/heads/main)
      ;;
    refs/heads/*)
      case "$new_oid" in
        ''|*[!0]*)
          echo "Agentlas main-only guard: refusing local branch update: $ref_name" >&2
          echo "Commit directly on local main; do not create branches or worktrees." >&2
          exit 1
          ;;
      esac
      ;;
  esac
done

exit 0
