#!/bin/sh
set -eu

while read -r local_ref local_oid remote_ref remote_oid; do
  case "$remote_ref" in
    refs/heads/main)
      ;;
    refs/heads/*)
      case "$local_oid" in
        ''|*[!0]*)
          echo "Agentlas main-only guard: refusing push to $remote_ref" >&2
          echo "Only main and intentional tags may be pushed." >&2
          exit 1
          ;;
      esac
      ;;
  esac
done

exit 0
