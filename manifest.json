{
  "schemaVersion": "1.0",
  "package": "hephaestus",
  "version": "0.7.21",
  "description": "Portable three-agent meta-agent team with a local-first ontology runtime for source archive, GraphRAG, Memory Curator tickets, and Agent Working Memory.",
  "entrypoints": {
    "canonical": "AGENTS.md",
    "singleAgent": "agent.md",
    "codexPlugin": "codex/plugins/agentlas-core-engine-meta-agent/.codex-plugin/plugin.json",
    "codexMarketplace": ".agents/plugins/marketplace.json",
    "claudeMarketplace": ".claude-plugin/marketplace.json",
    "claudePlugin": "claude/plugins/agentlas-core-engine-meta-agent/.claude-plugin/plugin.json",
    "hephaestusCli": "bin/hephaestus",
    "claudeCommand": ".claude/commands/meta-agent.md",
    "claudeHephaestusBuildCommand": ".claude/commands/hep-build.md",
    "claudeHephaestusNetworkCommand": ".claude/commands/hep-network.md",
    "claudeHephaestusCloudCommand": ".claude/commands/hep-cloud.md",
    "claudeHephaestusSearchCommand": ".claude/commands/hep-search.md",
    "claudeHephaestusCallCommand": ".claude/commands/hep-call.md",
    "claudeHephaestusUploadCommand": ".claude/commands/hep-upload.md",
    "codexHephaestusBuildPrompt": "codex/prompts/hep-build.md",
    "codexHephaestusNetworkPrompt": "codex/prompts/hep-network.md",
    "codexHephaestusCloudPrompt": "codex/prompts/hep-cloud.md",
    "codexHephaestusSearchPrompt": "codex/prompts/hep-search.md",
    "codexHephaestusCallPrompt": "codex/prompts/hep-call.md",
    "codexHephaestusUploadPrompt": "codex/prompts/hep-upload.md",
    "geminiExtension": "gemini/extension/gemini-extension.json",
    "geminiHephaestusBuildCommand": "gemini/extension/commands/hep-build.toml",
    "geminiHephaestusNetworkCommand": "gemini/extension/commands/hep-network.toml",
    "geminiHephaestusCloudCommand": "gemini/extension/commands/hep-cloud.toml",
    "geminiHephaestusSearchCommand": "gemini/extension/commands/hep-search.toml",
    "geminiHephaestusCallCommand": "gemini/extension/commands/hep-call.toml",
    "geminiHephaestusUploadCommand": "gemini/extension/commands/hep-upload.toml",
    "antigravityBuildWorkflow": "antigravity/workflows/hep-build.md",
    "antigravityNetworkWorkflow": "antigravity/workflows/hep-network.md",
    "antigravityCloudWorkflow": "antigravity/workflows/hep-cloud.md",
    "antigravitySearchWorkflow": "antigravity/workflows/hep-search.md",
    "antigravityCallWorkflow": "antigravity/workflows/hep-call.md",
    "antigravityUploadWorkflow": "antigravity/workflows/hep-upload.md",
    "globalCommands": ".agentlas/global-commands.json",
    "gemini": "GEMINI.md",
    "installer": "scripts/install.sh",
    "ontologyCli": "bin/ontology",
    "ontologyRuntime": "ontology/__init__.py",
    "ontologyVerification": "scripts/verify-ontology-runtime.sh"
  },
  "coreAgents": [
    "agents/10-single-agent-builder/agent.md",
    "agents/20-multi-agent-team-builder/agent.md",
    "agents/30-agentlas-packager/agent.md"
  ],
  "requiredConcepts": [
    "single-agent-builder",
    "multi-agent-team-builder",
    "agentlas-packager",
    "self-evolving-single-agent",
    "memory-architecture",
    "all-llm-runtime-architecture",
    "runtime-adapters",
    "global-command-registry",
    "policy-gate",
    "eval-release-review",
    "public-packaging",
    "production-ontology-runtime"
  ],
  "requiredDirectories": [
    "agents",
    "modes",
    "skills",
    ".agents",
    ".agentlas",
    ".claude-plugin",
    ".claude",
    "claude",
    ".gemini",
    "codex",
    "antigravity",
    "schemas",
    "templates",
    "docs",
    "scripts",
    "ontology",
    "bin",
    "tests",
    "examples"
  ]
}
