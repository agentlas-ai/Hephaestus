{
  "schemaVersion": "1.0",
  "name": "agentlas-meta-agent",
  "slug": "agentlas-meta-agent",
  "summary": "Portable meta-agent team for creating Codex, Claude Code, Gemini, and AGENTS.md-compatible agent repositories.",
  "capabilities": [
    "single_agent_builder",
    "multi_agent_team_builder",
    "agentlas_packager",
    "self_evolving_single_agent",
    "package_existing_agents",
    "agent_repo_design",
    "agent_team_design",
    "runtime_adapter_generation",
    "memory_ticket_contracts",
    "sitemap_task_bias",
    "pm_soul_architecture",
    "llm_runtime_architecture",
    "public_plugin_packaging",
    "install_verification"
  ],
  "defaultRuntime": "agents-md",
  "entrypoints": {
    "portable": "AGENTS.md",
    "agent": ".agents/agentlas-core-engine-meta-agent/agent.md",
    "codex": "codex/marketplace.json",
    "claude": ".claude/commands/meta-agent.md",
    "gemini": "GEMINI.md"
  },
  "contracts": {
    "modes": ".agentlas/mode-map.json",
    "sitemap": ".agentlas/sitemap.json",
    "pmSoul": ".agentlas/project-soul-memory.md",
    "memory": ".agentlas/memory-map.json",
    "runtimeArchitecture": "docs/llm-runtime-architecture.md",
    "chainMap": "docs/chain-map.md"
  }
}
