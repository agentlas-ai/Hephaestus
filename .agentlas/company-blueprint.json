{
  "schemaVersion": "1.0",
  "teamId": "agentlas-meta-agent",
  "name": "agentlas-meta-agent",
  "topology": "hub-and-spoke",
  "orchestrator": "AGENTS.md",
  "router": "AGENTS.md",
  "nodes": [
    {
      "id": "10-single-agent-builder",
      "role": "Single Agent Builder",
      "tier": 1,
      "path": "agents/10-single-agent-builder/agent.md"
    },
    {
      "id": "20-multi-agent-team-builder",
      "role": "Multi Agent Team Builder",
      "tier": 1,
      "path": "agents/20-multi-agent-team-builder/agent.md"
    },
    {
      "id": "30-agentlas-packager",
      "role": "Agentlas Packager",
      "tier": 1,
      "path": "agents/30-agentlas-packager/agent.md"
    }
  ],
  "edges": [
    {
      "from": "AGENTS.md",
      "to": "10-single-agent-builder",
      "handoff": "create one installable self-evolving worker package"
    },
    {
      "from": "AGENTS.md",
      "to": "20-multi-agent-team-builder",
      "handoff": "create a multi-role team package"
    },
    {
      "from": "AGENTS.md",
      "to": "30-agentlas-packager",
      "handoff": "repair or package existing agents and teams into Agentlas architecture"
    },
    {
      "from": "10-single-agent-builder",
      "to": "30-agentlas-packager",
      "handoff": "optional distribution packaging after single-agent generation"
    },
    {
      "from": "20-multi-agent-team-builder",
      "to": "30-agentlas-packager",
      "handoff": "optional distribution packaging after team generation"
    }
  ],
  "architectureComponentsGeneratedInOutputs": [
    "orchestrator_or_hq",
    "pm_soul",
    "memory_curator",
    "memory_tickets",
    "policy_gate",
    "eval_judge",
    "qa_evidence_gate",
    "sitemap_task_bias",
    "llm_runtime_architecture",
    "thin_runtime_adapters",
    "install_verification"
  ],
  "policy": {
    "peerToPeerWorkerCalls": "route-through-root",
    "durableMemoryWrites": "through-memory-tickets",
    "runtimeAdapters": "thin-adapters-over-canonical-core",
    "publicRelease": "requires-public-safety-check"
  }
}
