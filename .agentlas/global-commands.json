{
  "schemaVersion": "1.0",
  "packageId": "agentlas-core-engine-meta-agent",
  "canonicalCommand": "/hephaestus-build",
  "commands": [
    {
      "runtime": "claude-code",
      "command": "/hephaestus-build",
      "adapterPath": ".claude/commands/hephaestus-build.md",
      "globalInstallPath": "~/.claude/commands/hephaestus-build.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "Build/create/package surface."
    },
    {
      "runtime": "codex",
      "command": "/prompts:hephaestus-build",
      "adapterPath": "codex/prompts/hephaestus-build.md",
      "globalInstallPath": "~/.codex/prompts/hephaestus-build.md",
      "scope": "global",
      "status": "custom-prompt-slash-command",
      "notes": "Codex plugins cannot register slash commands (skills only). The explicit build surface is namespaced as /prompts:hephaestus-build."
    },
    {
      "runtime": "gemini-cli",
      "command": "/hephaestus-build",
      "adapterPath": "gemini/extension/commands/hephaestus-build.toml",
      "globalInstallPath": "gemini extensions install https://github.com/agentlas-ai/Hephaestus --ref v0.7.5",
      "scope": "global",
      "status": "extension-custom-command",
      "notes": "Fallback user command is also installable at ~/.gemini/commands/hephaestus-build.toml."
    },
    {
      "runtime": "antigravity",
      "command": "/hephaestus-build",
      "adapterPath": "antigravity/workflows/hephaestus-build.md",
      "globalInstallPath": "~/.gemini/antigravity/global_workflows/hephaestus-build.md",
      "scope": "global",
      "status": "workflow-slash-command",
      "notes": "Installed by scripts/install-all-runtimes.sh. Project-scope fallback ships at .agents/workflows/hephaestus-build.md."
    },
    {
      "runtime": "generic-agents-md",
      "command": "/hephaestus-build",
      "adapterPath": "AGENTS.md",
      "scope": "project",
      "status": "adapter-command-alias",
      "notes": "Build/create/package surface. AGENTS.md and Cursor rules also accept @Hephaestus as a project-rule fallback."
    },
    {
      "runtime": "agentlas-terminal",
      "command": "hephaestus-build",
      "adapterPath": "bin/hephaestus-build",
      "globalInstallPath": "hephaestus-build \"<request>\"",
      "scope": "terminal",
      "status": "shell-command"
    },
    {
      "runtime": "agentlas-terminal",
      "command": "Hephaestus-build",
      "adapterPath": "bin/hephaestus-build",
      "globalInstallPath": "Hephaestus-build \"<request>\"",
      "scope": "terminal",
      "status": "shell-command-alias",
      "notes": "Human-facing build alias installed by scripts/install-all-runtimes.sh; same builder surface as /hephaestus-build."
    },
    {
      "runtime": "cursor",
      "command": "/hephaestus-build",
      "adapterPath": "cursor/plugin/commands/hephaestus-build.md",
      "globalInstallPath": "~/.cursor/commands/hephaestus-build.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "Build/create/package surface. Cursor also keeps the @Hephaestus project-rule fallback."
    },
    {
      "runtime": "opencode",
      "command": "/hephaestus-build",
      "adapterPath": "opencode/commands/hephaestus-build.md",
      "globalInstallPath": "~/.config/opencode/commands/hephaestus-build.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "Build/create/package surface."
    },
    {
      "runtime": "claude-code",
      "command": "/hephaestus-network",
      "adapterPath": ".claude/commands/hephaestus-network.md",
      "globalInstallPath": "~/.claude/commands/hephaestus-network.md",
      "scope": "global",
      "status": "native-slash-command"
    },
    {
      "runtime": "codex",
      "command": "/prompts:hephaestus-network",
      "adapterPath": "codex/prompts/hephaestus-network.md",
      "globalInstallPath": "~/.codex/prompts/hephaestus-network.md",
      "scope": "global",
      "status": "custom-prompt-slash-command",
      "notes": "Implicit/skill surface: codex/plugins/agentlas-core-engine-meta-agent/skills/hephaestus-network/SKILL.md ($hephaestus-network). Tool surface: mcp_servers.hephaestus-network in ~/.codex/config.toml."
    },
    {
      "runtime": "gemini-cli",
      "command": "/hephaestus-network",
      "adapterPath": "gemini/extension/commands/hephaestus-network.toml",
      "globalInstallPath": "gemini extensions install https://github.com/agentlas-ai/Hephaestus --ref v0.7.5",
      "scope": "global",
      "status": "extension-custom-command",
      "notes": "Fallback user command is also installable at ~/.gemini/commands/hephaestus-network.toml."
    },
    {
      "runtime": "antigravity",
      "command": "/hephaestus-network",
      "adapterPath": "antigravity/workflows/hephaestus-network.md",
      "globalInstallPath": "~/.gemini/antigravity/global_workflows/hephaestus-network.md",
      "scope": "global",
      "status": "workflow-slash-command",
      "notes": "Project-scope fallback ships at .agents/workflows/hephaestus-network.md."
    },
    {
      "runtime": "cursor",
      "command": "/hephaestus-network",
      "adapterPath": "cursor/plugin/commands/hephaestus-network.md",
      "globalInstallPath": "~/.cursor/commands/hephaestus-network.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "Cursor ≥1.6 supports commands (~/.cursor/commands), Cursor ≥2.4 skills (~/.cursor/skills, ~/.agents/skills). cursor/plugin/ is the marketplace-ready bundle."
    },
    {
      "runtime": "cursor",
      "command": "@Hephaestus",
      "adapterPath": "cursor/rules/hephaestus.mdc",
      "globalInstallPath": "<project>/.cursor/rules/hephaestus.mdc",
      "scope": "project",
      "status": "rule-trigger-fallback",
      "notes": "Per-project rule fallback; reacts to /hephaestus-network and @Hephaestus routing mentions."
    },
    {
      "runtime": "opencode",
      "command": "/hephaestus-network",
      "adapterPath": "opencode/commands/hephaestus-network.md",
      "globalInstallPath": "~/.config/opencode/commands/hephaestus-network.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "OpenCode also reads the universal skill at ~/.agents/skills/hephaestus-network and supports MCP (opencode/README.md)."
    },
    {
      "runtime": "openclaw",
      "command": "/skill hephaestus-network",
      "adapterPath": "openclaw/skills/hephaestus-network/SKILL.md",
      "globalInstallPath": "~/.openclaw/skills/hephaestus-network/SKILL.md",
      "scope": "global",
      "status": "skill-slash-command",
      "notes": "AgentSkills spec; native /hephaestus-network registration follows commands.nativeSkills. Also loaded from ~/.agents/skills."
    },
    {
      "runtime": "hermes-agent",
      "command": "hephaestus-network",
      "adapterPath": "hermes/skills/hephaestus-network/SKILL.md",
      "globalInstallPath": "~/.hermes/skills/hephaestus-network/SKILL.md",
      "scope": "global",
      "status": "skill",
      "notes": "AgentSkills spec skill; MCP server registration in ~/.hermes/config.yaml (hermes/README.md)."
    },
    {
      "runtime": "agentlas-terminal",
      "command": "hephaests-network",
      "adapterPath": "bin/hephaests-network",
      "globalInstallPath": "hephaests-network \"<request>\"",
      "scope": "terminal",
      "status": "shell-command-alias",
      "notes": "Typo-tolerant standalone Network alias; maps to hephaestus hephaests-network \"<request>\" and forces Hub-only Network routing."
    },
    {
      "runtime": "claude-code",
      "command": "/hephaestus-cloud",
      "adapterPath": ".claude/commands/hephaestus-cloud.md",
      "globalInstallPath": "~/.claude/commands/hephaestus-cloud.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "Owner-scoped leg of the three-scope model: searches ONLY the signed-in user's own cloud packages (보관함), call-priced at a flat 1 credit. Maps to `hephaestus route --scope cloud` (implies --hub-only, cargo.* owner query)."
    },
    {
      "runtime": "codex",
      "command": "/prompts:hephaestus-cloud",
      "adapterPath": "codex/prompts/hephaestus-cloud.md",
      "globalInstallPath": "~/.codex/prompts/hephaestus-cloud.md",
      "scope": "global",
      "status": "custom-prompt-slash-command",
      "notes": "Implicit/skill surface: codex/plugins/agentlas-core-engine-meta-agent/skills/hephaestus-cloud/SKILL.md ($hephaestus-cloud). Tool surface: hephaestus_cloud_search in mcp_servers.hephaestus-network."
    },
    {
      "runtime": "gemini-cli",
      "command": "/hephaestus-cloud",
      "adapterPath": "gemini/extension/commands/hephaestus-cloud.toml",
      "globalInstallPath": "gemini extensions install https://github.com/agentlas-ai/Hephaestus --ref v0.7.5",
      "scope": "global",
      "status": "extension-custom-command",
      "notes": "Fallback user command is also installable at ~/.gemini/commands/hephaestus-cloud.toml."
    },
    {
      "runtime": "antigravity",
      "command": "/hephaestus-cloud",
      "adapterPath": "antigravity/workflows/hephaestus-cloud.md",
      "globalInstallPath": "~/.gemini/antigravity/global_workflows/hephaestus-cloud.md",
      "scope": "global",
      "status": "workflow-slash-command",
      "notes": "Project-scope fallback ships at .agents/workflows/hephaestus-cloud.md."
    },
    {
      "runtime": "cursor",
      "command": "/hephaestus-cloud",
      "adapterPath": "cursor/plugin/commands/hephaestus-cloud.md",
      "globalInstallPath": "~/.cursor/commands/hephaestus-cloud.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "Owner cloud (보관함) only. cursor/plugin/ is the marketplace-ready bundle."
    },
    {
      "runtime": "opencode",
      "command": "/hephaestus-cloud",
      "adapterPath": "opencode/commands/hephaestus-cloud.md",
      "globalInstallPath": "~/.config/opencode/commands/hephaestus-cloud.md",
      "scope": "global",
      "status": "native-slash-command",
      "notes": "OpenCode also reads the universal skill at ~/.agents/skills/hephaestus-cloud and supports MCP (hephaestus_cloud_search)."
    },
    {
      "runtime": "openclaw",
      "command": "/skill hephaestus-cloud",
      "adapterPath": "openclaw/skills/hephaestus-cloud/SKILL.md",
      "globalInstallPath": "~/.openclaw/skills/hephaestus-cloud/SKILL.md",
      "scope": "global",
      "status": "skill-slash-command",
      "notes": "AgentSkills spec; native /hephaestus-cloud registration follows commands.nativeSkills. Also loaded from ~/.agents/skills."
    },
    {
      "runtime": "hermes-agent",
      "command": "hephaestus-cloud",
      "adapterPath": "hermes/skills/hephaestus-cloud/SKILL.md",
      "globalInstallPath": "~/.hermes/skills/hephaestus-cloud/SKILL.md",
      "scope": "global",
      "status": "skill",
      "notes": "AgentSkills spec skill; MCP server registration in ~/.hermes/config.yaml (hephaestus_cloud_search tool)."
    },
    {
      "runtime": "mcp",
      "command": "hephaestus_cloud_search",
      "adapterPath": "agentlas_cloud/mcp_stdio.py",
      "globalInstallPath": "~/.agentlas/runtime/current/bin/hephaestus mcp serve",
      "scope": "global",
      "status": "mcp-tool",
      "notes": "Owner-scoped (scope=cloud) sibling of hephaestus_route: searches only the signed-in user's own cloud packages (보관함)."
    },
    {
      "runtime": "agentlas-terminal",
      "command": "hephaestus cloud",
      "adapterPath": "bin/hephaestus",
      "globalInstallPath": "hephaestus cloud \"<request>\"",
      "scope": "terminal",
      "status": "shell-command",
      "notes": "hephaestus cloud \"<request>\" is shorthand for hephaestus route \"<request>\" --scope cloud (owner cloud / 보관함 only)."
    },
    {
      "runtime": "mcp",
      "command": "hephaestus_route",
      "adapterPath": "agentlas_cloud/mcp_stdio.py",
      "globalInstallPath": "~/.agentlas/runtime/current/bin/hephaestus mcp serve",
      "scope": "global",
      "status": "mcp-tool",
      "notes": "stdio MCP server for any MCP-capable harness, incl. Ollama-launched local models (Gemma, DeepSeek): docs/local-models.md."
    },
    {
      "runtime": "generic-agents-md",
      "command": "@Hephaestus",
      "adapterPath": "AGENTS.md",
      "scope": "project",
      "status": "adapter-command-alias",
      "notes": "Generic fallback for AGENTS.md-compatible and local-model runtimes (Gemma, Hermes-like): see docs/runtime-fallback-adapters.md."
    },
    {
      "runtime": "agentlas-terminal",
      "command": "hephaestus route",
      "adapterPath": "bin/hephaestus",
      "globalInstallPath": "hephaestus \"<request>\"",
      "scope": "terminal",
      "status": "shell-command",
      "notes": "hephaestus \"<request>\" is shorthand for hephaestus route \"<request>\"."
    }
  ],
  "postCreationUserMessage": {
    "required": true,
    "template": "global_commands: Claude Code /hephaestus-build, /hephaestus-network, /hephaestus-cloud; Codex /prompts:hephaestus-build, /prompts:hephaestus-network, /prompts:hephaestus-cloud; Gemini CLI /hephaestus-build, /hephaestus-network, /hephaestus-cloud; Antigravity /hephaestus-build, /hephaestus-network, /hephaestus-cloud; Cursor /hephaestus-build, /hephaestus-network, /hephaestus-cloud; OpenCode /hephaestus-build, /hephaestus-network, /hephaestus-cloud; Agentlas terminal Hephaestus-build, hephaests-network, or hephaestus cloud. Meaning: build/create = /hephaestus-build; borrow public Hub agents = /hephaestus-network; share/use my Agentlas Cloud packages = /hephaestus-cloud."
  }
}
