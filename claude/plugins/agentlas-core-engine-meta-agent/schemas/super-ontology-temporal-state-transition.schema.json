{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.dev/schemas/super-ontology-temporal-state-transition.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "state",
    "runtimePromotionAllowed",
    "defaultDecision",
    "stateSubjectFamilies",
    "eventArtifactTypes",
    "temporalEvents",
    "lifecycleStates",
    "validTimeStates",
    "transactionTimeStates",
    "eventOrderStates",
    "stateTransitionStates",
    "projectionStates",
    "authorityStates",
    "requiredTemporalEvidence",
    "decisions",
    "researchBasis",
    "hardStops"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": { "const": "agentlas-super-ontology-temporal-state-transition" },
    "state": { "enum": ["export_only", "local_candidate", "shadow", "canary", "active", "archived"] },
    "runtimePromotionAllowed": { "const": false },
    "defaultDecision": { "type": "string" },
    "stateSubjectFamilies": { "type": "array", "items": { "type": "string" }, "minItems": 16 },
    "eventArtifactTypes": { "type": "array", "items": { "type": "string" }, "minItems": 14 },
    "temporalEvents": { "type": "array", "items": { "type": "string" }, "minItems": 16 },
    "lifecycleStates": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "validTimeStates": { "type": "array", "items": { "type": "string" }, "minItems": 11 },
    "transactionTimeStates": { "type": "array", "items": { "type": "string" }, "minItems": 9 },
    "eventOrderStates": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "stateTransitionStates": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "projectionStates": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "authorityStates": { "type": "array", "items": { "type": "string" }, "minItems": 7 },
    "requiredTemporalEvidence": { "type": "array", "items": { "type": "string" }, "minItems": 24 },
    "decisions": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "researchBasis": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "hardStops": { "type": "array", "items": { "type": "string" }, "minItems": 20 }
  },
  "additionalProperties": false
}
