{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/workforce-source-bundle-verification.schema.json",
  "title": "Agentlas Workforce Exact Source Bundle Verification v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "verification",
    "source",
    "sourceSelectionSessionId",
    "sourceCandidateSetDigest",
    "agentDefinitionId",
    "agentReleaseId",
    "releaseVersion",
    "packageHash",
    "contentDigest",
    "entityKind",
    "receiptDigest"
  ],
  "properties": {
    "schemaVersion": { "const": "agentlas.workforce-source-bundle-verification.v1" },
    "status": { "const": "verified" },
    "verification": { "enum": ["verified_transport", "verified_signature"] },
    "source": { "enum": ["cloud", "hub"] },
    "sourceSelectionSessionId": { "$ref": "#/$defs/id" },
    "sourceCandidateSetDigest": { "$ref": "#/$defs/hash" },
    "agentDefinitionId": { "$ref": "#/$defs/id" },
    "agentReleaseId": { "$ref": "#/$defs/id" },
    "releaseVersion": { "type": "string", "minLength": 1, "maxLength": 100 },
    "packageHash": { "$ref": "#/$defs/hash" },
    "contentDigest": { "$ref": "#/$defs/hash" },
    "entityKind": { "enum": ["agent", "team"] },
    "receiptDigest": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]{1,255}$" },
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
