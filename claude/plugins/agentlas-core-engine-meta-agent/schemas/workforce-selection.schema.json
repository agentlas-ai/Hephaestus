{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/workforce-selection.schema.json",
  "title": "Agentlas Host LLM Workforce Selection",
  "$comment": "The host boundary additionally requires slot, release, edge, and expansion IDs from the exact WorkOrder/CandidateSet and reason codes from the finite public v1 or exact candidate evidence vocabulary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "selectionSessionId", "candidateSetDigest",
    "decisionAuthor", "assignments", "edges", "alternativesConsidered",
    "requestExpansionForSlots"
  ],
  "properties": {
    "schemaVersion": { "const": "agentlas.workforce-selection.v1" },
    "selectionSessionId": { "$ref": "#/$defs/id" },
    "candidateSetDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "decisionAuthor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "modelId", "runtimeId"],
      "properties": {
        "kind": { "const": "host_llm" },
        "modelId": { "$ref": "#/$defs/id" },
        "runtimeId": { "type": ["string", "null"], "maxLength": 255 }
      }
    },
    "assignments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slotId", "agentReleaseId", "reasonCodes"],
        "properties": {
          "slotId": { "$ref": "#/$defs/id" },
          "agentReleaseId": { "$ref": "#/$defs/id" },
          "reasonCodes": { "$ref": "#/$defs/ids" }
        }
      }
    },
    "edges": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fromSlot", "toSlot", "relation", "artifactKinds"],
        "properties": {
          "fromSlot": { "$ref": "#/$defs/id" },
          "toSlot": { "$ref": "#/$defs/id" },
          "relation": { "enum": ["reportsTo", "handsOffTo", "reviews", "coordinatesWith"] },
          "artifactKinds": { "$ref": "#/$defs/ids" }
        }
      }
    },
    "alternativesConsidered": { "$ref": "#/$defs/ids" },
    "requestExpansionForSlots": { "$ref": "#/$defs/ids" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]{1,255}$" },
    "ids": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
  }
}
