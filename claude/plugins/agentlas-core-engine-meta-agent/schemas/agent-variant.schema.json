{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/agent-variant.schema.json",
  "title": "Agentlas AgentVariant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "variantId", "variantOwnerRef", "baseAgentReleaseId",
    "experiencePackReleaseId", "compositionMode", "bindingHash", "compatibilityStatus",
    "visibility", "status"
  ],
  "properties": {
    "schemaVersion": { "const": "agentlas.agent-variant.v1" },
    "kind": { "const": "agentlas-agent-variant" },
    "variantId": { "$ref": "#/$defs/id" },
    "variantOwnerRef": { "$ref": "#/$defs/id" },
    "baseAgentReleaseId": { "$ref": "#/$defs/id" },
    "experiencePackReleaseId": { "$ref": "#/$defs/id" },
    "compositionMode": { "const": "references-only" },
    "bindingHash": { "$ref": "#/$defs/hash" },
    "compatibilityStatus": { "enum": ["unverified", "verified", "incompatible", "stale"] },
    "verificationReceiptIds": { "type": "array", "maxItems": 24, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "visibility": { "enum": ["private", "unlisted", "public"] },
    "status": { "enum": ["draft", "active", "dormant", "suspended", "withdrawn", "deleted"] },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "compatibilityStatus": { "const": "verified" } }, "required": ["compatibilityStatus"] },
      "then": { "required": ["verificationReceiptIds"], "properties": { "verificationReceiptIds": { "minItems": 1 } } }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]{2,255}$" },
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
