{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.ai/schemas/experience-item.schema.json",
  "title": "Agentlas ExperienceItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "kind", "experienceItemId", "experiencePackId",
    "experiencePackReleaseId", "type", "summary", "instructions", "taskSignatures",
    "environmentConstraints", "evidenceReceiptIds", "supersedesItemIds", "confidence",
    "status", "privacyScope"
  ],
  "properties": {
    "schemaVersion": { "const": "agentlas.experience-item.v1" },
    "kind": { "const": "agentlas-experience-item" },
    "experienceItemId": { "$ref": "#/$defs/id" },
    "experiencePackId": { "$ref": "#/$defs/id" },
    "experiencePackReleaseId": { "$ref": "#/$defs/id" },
    "type": { "enum": ["procedure", "failure-recovery", "environment-gotcha", "tool-affordance", "warning", "supersedes"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 320 },
    "instructions": {
      "type": "array", "minItems": 1, "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 600 }
    },
    "taskSignatures": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "environmentConstraints": { "type": "array", "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 240 } },
    "evidenceReceiptIds": { "type": "array", "minItems": 1, "maxItems": 24, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "supersedesItemIds": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "enum": ["candidate", "promoted", "deprecated", "rejected"] },
    "privacyScope": { "enum": ["private", "public-safe"] },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@-]{2,255}$" }
  }
}
