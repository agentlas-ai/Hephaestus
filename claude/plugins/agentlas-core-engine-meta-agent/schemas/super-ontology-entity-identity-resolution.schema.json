{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.dev/schemas/super-ontology-entity-identity-resolution.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "state",
    "runtimePromotionAllowed",
    "defaultDecision",
    "entityFamilies",
    "mentionArtifactTypes",
    "identityEvents",
    "resolutionStates",
    "matchSignalStates",
    "conflictStates",
    "temporalStates",
    "privacyStates",
    "authorityStates",
    "requiredIdentityEvidence",
    "decisions",
    "researchBasis",
    "hardStops"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": { "const": "agentlas-super-ontology-entity-identity-resolution" },
    "state": { "enum": ["export_only", "local_candidate", "shadow", "canary", "active", "archived"] },
    "runtimePromotionAllowed": { "const": false },
    "defaultDecision": { "type": "string" },
    "entityFamilies": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "mentionArtifactTypes": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "identityEvents": { "type": "array", "items": { "type": "string" }, "minItems": 12 },
    "resolutionStates": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "matchSignalStates": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "conflictStates": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "temporalStates": { "type": "array", "items": { "type": "string" }, "minItems": 9 },
    "privacyStates": { "type": "array", "items": { "type": "string" }, "minItems": 8 },
    "authorityStates": { "type": "array", "items": { "type": "string" }, "minItems": 7 },
    "requiredIdentityEvidence": { "type": "array", "items": { "type": "string" }, "minItems": 20 },
    "decisions": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "researchBasis": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "hardStops": { "type": "array", "items": { "type": "string" }, "minItems": 20 }
  },
  "additionalProperties": false
}
